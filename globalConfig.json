{
    "meta": {
        "name": "TA-crowdstrike_falcon_discover",
        "displayName": "CrowdStrike Falcon Discover Add-on for Splunk",
        "version": "0.0.0+004a135",
        "restRoot": "TA_crowdstrike_falcon_discover",
        "schemaVersion": "0.0.9"
    },
    "pages": {
        "configuration": {
            "title": "Configuration",
            "description": "Set up your add-on",
            "tabs": [
                {
                    "name": "account",
                    "title": "Account",
                    "table": {
                        "header": [
                            {
                                "field": "name",
                                "label": "Account name"
                            },
                            {
                                "field": "client_id",
                                "label": "Client ID"
                            }
                        ],
                        "actions": [
                            "edit",
                            "delete",
                            "clone"
                        ]
                    },
                    "entity": [
                        {
                            "field": "name",
                            "label": "Account name",
                            "type": "text",
                            "required": true,
                            "help": "Enter a unique name for this account.",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 50,
                                    "errorMsg": "Length of Account name should be between 1 and 50"
                                },
                                {
                                    "type": "regex",
                                    "pattern": "^[a-zA-Z]\\w*$",
                                    "errorMsg": "Account name must start with a letter and followed by alphabetic letters, digits or underscores."
                                }
                            ]
                        },
                        {
                            "field": "client_id",
                            "label": "Client ID",
                            "type": "text",
                            "required": true,
                            "help": "Enter the CrowdStrike API Client ID",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 100,
                                    "errorMsg": "Length of Client ID should be between 1 and 100"
                                }
                            ]
                        },
                        {
                            "field": "client_secret",
                            "label": "Client Secret",
                            "type": "text",
                            "encrypted": true,
                            "required": true,
                            "help": "Enter the CrowdStrike API Client Secret",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 100,
                                    "errorMsg": "Length of Client Secret should be between 1 and 100"
                                }
                            ]
                        },
                        {
                            "field": "member_cid",
                            "label": "Customer ID",
                            "type": "text",
                            "required": false,
                            "help": "(optional) Enter the Customer ID of a child tenant (e.g. for MSSP)",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 100,
                                    "errorMsg": "Length of Customer ID should be between 1 and 100"
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "proxy",
                    "title": "Proxy",
                    "entity": [
                        {
                            "field": "proxy_enabled",
                            "label": "Enable",
                            "type": "checkbox"
                        },
                        {
                            "field": "proxy_type",
                            "label": "Proxy Type",
                            "type": "singleSelect",
                            "options": {
                                "disableSearch": true,
                                "autoCompleteFields": [
                                    {
                                        "label": "http",
                                        "value": "http"
                                    },
                                    {
                                        "label": "socks4",
                                        "value": "socks4"
                                    },
                                    {
                                        "label": "socks5",
                                        "value": "socks5"
                                    }
                                ]
                            },
                            "defaultValue": "http"
                        },
                        {
                            "field": "proxy_url",
                            "label": "Host",
                            "type": "text",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 0,
                                    "maxLength": 4096,
                                    "errorMsg": "Max host length is 4096"
                                }
                            ]
                        },
                        {
                            "field": "proxy_port",
                            "label": "Port",
                            "type": "text",
                            "validators": [
                                {
                                    "type": "number",
                                    "range": [
                                        1,
                                        65535
                                    ]
                                }
                            ]
                        },
                        {
                            "field": "proxy_username",
                            "label": "Username",
                            "type": "text",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 0,
                                    "maxLength": 50,
                                    "errorMsg": "Max length of username is 50"
                                }
                            ]
                        },
                        {
                            "field": "proxy_password",
                            "label": "Password",
                            "type": "text",
                            "encrypted": true,
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 0,
                                    "maxLength": 8192,
                                    "errorMsg": "Max length of password is 8192"
                                }
                            ]
                        },
                        {
                            "field": "proxy_rdns",
                            "label": "Remote DNS resolution",
                            "type": "checkbox"
                        }
                    ],
                    "options": {
                        "saveValidator": "function(formData) { if(!formData.proxy_enabled || formData.proxy_enabled === '0') {return true; } if(!formData.proxy_url) { return 'Proxy Host can not be empty'; } if(!formData.proxy_port) { return 'Proxy Port can not be empty'; } return true; }"
                    }
                },
                {
                    "type": "loggingTab"
                }
            ]
        },
        "inputs": {
            "title": "Inputs",
            "description": "Manage your data inputs",
            "table": {
                "header": [
                    {
                        "field": "name",
                        "label": "Name"
                    },
                    {
                        "field": "interval",
                        "label": "Interval"
                    },
                    {
                        "field": "cron_schedule",
                        "label": "Cron Schedule"
                    },
                    {
                        "field": "index",
                        "label": "Index"
                    },
                    {
                        "field": "disabled",
                        "label": "Status"
                    }
                ],
                "moreInfo": [
                    {
                        "field": "name",
                        "label": "Name"
                    },
                    {
                        "field": "interval",
                        "label": "Interval"
                    },
                    {
                        "field": "cron_schedule",
                        "label": "Cron Schedule"
                    },
                    {
                        "field": "index",
                        "label": "Index"
                    },
                    {
                        "field": "disabled",
                        "label": "Status"
                    },
                    {
                        "field": "cs_account",
                        "label": "CrowdStrike Account"
                    },
                    {
                        "field": "excluded_fields",
                        "label": "Excluded Fields"
                    },
                    {
                        "field": "verify",
                        "label": "Verify Certificate"
                    }
                ],
                "actions": [
                    "edit",
                    "delete",
                    "clone"
                ]
            },
            "services": [
                {
                    "name": "input_cs_hosts",
                    "title": "CrowdStrike Discover Host Input",
                    "entity": [
                        {
                            "field": "name",
                            "label": "Name",
                            "type": "text",
                            "help": "Enter a unique name for the data input",
                            "required": true,
                            "validators": [
                                {
                                    "type": "regex",
                                    "pattern": "^[a-zA-Z]\\w*$",
                                    "errorMsg": "Input Name must start with a letter and followed by alphabetic letters, digits or underscores."
                                },
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 100,
                                    "errorMsg": "Length of input name should be between 1 and 100"
                                }
                            ]
                        },
                        {
                            "type": "interval",
                            "field": "interval",
                            "label": "Interval",
                            "help": "The input is designed to run continuously (interval=0). Do not change this setting!",
                            "required": true,
                            "defaultValue": "0"
                        },
                        {
                            "field": "cron_schedule",
                            "label": "Cron Schedule",
                            "type": "text",
                            "defaultValue": "0 0 * * *",
                            "required": true,
                            "help": "Cron schedule expression how often data should be collected",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 80,
                                    "errorMsg": "Length of cron schedule expression should be between 1 and 80."
                                }
                            ]
                        },
                        {
                            "field": "index",
                            "label": "Index",
                            "type": "singleSelect",
                            "defaultValue": "default",
                            "options": {
                                "endpointUrl": "data/indexes",
                                "createSearchChoice": true,
                                "denyList": "^_.*$"
                            },
                            "required": true,
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 80,
                                    "errorMsg": "Length of index name should be between 1 and 80."
                                }
                            ]
                        },
                        {
                            "field": "cs_account",
                            "label": "CrowdStrike Account",
                            "help": "Select the account created on the Configuration tab.",
                            "required": true,
                            "type": "singleSelect",
                            "options": {
                                "referenceName": "account"
                            }
                        },
                        {
                            "field": "fql_filter_hosts",
                            "label": "FQL Filter - Hosts",
                            "help": "(optional) Filter hosts to collect from the Discover API.",
                            "required": false,
                            "type": "text",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 0,
                                    "maxLength": 8192,
                                    "errorMsg": "Max length of text input is 8192"
                                }
                            ]
                        },
                        {
                            "field": "fql_filter_hosts_help",
                            "label": " ",
                            "type": "helpLink",
                            "options": {
                                "text": "Available host filters",
                                "link": "https://falconpy.io/Service-Collections/Discover.html#available-filters-2"
                            }
                        },
                        {
                            "field": "excluded_fields",
                            "label": "Excluded Fields",
                            "help": "(optional) Comma-separated list of fields to exclude from indexing. Example: external_ip,os_version",
                            "required": false,
                            "type": "text",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 0,
                                    "maxLength": 8192,
                                    "errorMsg": "Max length of text input is 8192"
                                }
                            ]
                        },
                        {
                            "field": "verify",
                            "type": "checkbox",
                            "label": "Verify Certificate?",
                            "defaultValue": true
                        }
                    ]
                },
                {
                    "name": "input_cs_applications",
                    "title": "CrowdStrike Discover Application Input",
                    "entity": [
                        {
                            "field": "name",
                            "label": "Name",
                            "type": "text",
                            "help": "Enter a unique name for the data input",
                            "required": true,
                            "validators": [
                                {
                                    "type": "regex",
                                    "pattern": "^[a-zA-Z]\\w*$",
                                    "errorMsg": "Input Name must start with a letter and followed by alphabetic letters, digits or underscores."
                                },
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 100,
                                    "errorMsg": "Length of input name should be between 1 and 100"
                                }
                            ]
                        },
                        {
                            "type": "interval",
                            "field": "interval",
                            "label": "Interval",
                            "help": "The input is designed to run continuously (interval=0). Do not change this setting!",
                            "required": true,
                            "defaultValue": "0"
                        },
                        {
                            "field": "cron_schedule",
                            "label": "Cron Schedule",
                            "type": "text",
                            "defaultValue": "0 0 * * *",
                            "required": true,
                            "help": "Cron schedule expression how often data should be collected",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 80,
                                    "errorMsg": "Length of cron schedule expression should be between 1 and 80."
                                }
                            ]
                        },
                        {
                            "field": "index",
                            "label": "Index",
                            "type": "singleSelect",
                            "defaultValue": "default",
                            "options": {
                                "endpointUrl": "data/indexes",
                                "createSearchChoice": true,
                                "denyList": "^_.*$"
                            },
                            "required": true,
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 1,
                                    "maxLength": 80,
                                    "errorMsg": "Length of index name should be between 1 and 80."
                                }
                            ]
                        },
                        {
                            "field": "cs_account",
                            "label": "CrowdStrike Account",
                            "help": "Select the account created on the Configuration tab.",
                            "required": true,
                            "type": "singleSelect",
                            "options": {
                                "referenceName": "account"
                            }
                        },
                        {
                            "field": "fql_filter_devices",
                            "label": "FQL Filter - Devices",
                            "help": "(optional) Filter devices for which to collect application data.",
                            "required": false,
                            "type": "text",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 0,
                                    "maxLength": 8192,
                                    "errorMsg": "Max length of text input is 8192"
                                }
                            ]
                        },
                        {
                            "field": "fql_filter_devices_help",
                            "label": "",
                            "type": "helpLink",
                            "options": {
                                "text": "Available device filters",
                                "link": "https://falconpy.io/Service-Collections/Hosts.html#available-filters-1"
                            }
                        },
                        {
                            "field": "fql_filter_applications",
                            "label": "FQL Filter - Applications",
                            "help": "(optional) Filter applications to collect for each device.",
                            "required": false,
                            "type": "text",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 0,
                                    "maxLength": 8192,
                                    "errorMsg": "Max length of text input is 8192"
                                }
                            ]
                        },
                        {
                            "field": "fql_filter_applications_help",
                            "label": " ",
                            "type": "helpLink",
                            "options": {
                                "text": "Available application filters",
                                "link": "https://falconpy.io/Service-Collections/Discover.html#available-filters"
                            }
                        },
                        {
                            "field": "index_host_info",
                            "type": "checkbox",
                            "label": "Index host information for every application?",
                            "help": "e.g. hostname/platform/external_ip. If disabled, application events will \"only\" have an aid (agent/sensor ID) field for host correlation.",
                            "defaultValue": false
                        },
                        {
                            "field": "excluded_fields",
                            "label": "Excluded Fields",
                            "help": "(optional) Comma-separated list of fields to exclude from indexing. Example: name_vendor_version,host.kernel_version",
                            "required": false,
                            "type": "text",
                            "validators": [
                                {
                                    "type": "string",
                                    "minLength": 0,
                                    "maxLength": 8192,
                                    "errorMsg": "Max length of text input is 8192"
                                }
                            ]
                        },
                        {
                            "field": "num_worker_threads",
                            "label": "Number of worker threads",
                            "type": "text",
                            "defaultValue": 5,
                            "required": true,
                            "help": "Number of concurrent worker threads collecting data (1-10)",
                            "validators": [
                                {
                                    "type": "number",
                                    "range": [
                                        1,
                                        10
                                    ]
                                }
                            ]
                        },
                        {
                            "field": "verify",
                            "type": "checkbox",
                            "label": "Verify Certificate?",
                            "defaultValue": true
                        }
                    ]
                }
            ]
        }
    }
}
